# ── Database ────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (use the pooler/transaction URL)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# ── Auth ────────────────────────────────────────────────────────
# 256-bit random secret: run `openssl rand -base64 32` to generate
JWT_SECRET="your-256-bit-secret-here"

# ── Cloudflare R2 ────────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="keenkids-dev"
R2_PUBLIC_URL="https://your-bucket.your-subdomain.r2.dev"

# ── TurboWarp Coding Sandbox ─────────────────────────────────────
NEXT_PUBLIC_TURBOWARP_URL="https://coding.keenkids.app"
# For local dev, you can use the public TurboWarp instance temporarily:
# NEXT_PUBLIC_TURBOWARP_URL="https://turbowarp.org"

# ── AI Image Generation (Phase 2) ───────────────────────────────
OPENAI_API_KEY="sk-..."

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
